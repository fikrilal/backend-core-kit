{
  "name": "backend-core-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready NestJS backend boilerplate (Fastify, Postgres/Prisma, Redis/BullMQ, OpenTelemetry, OpenAPI contract gates).",
  "license": "UNLICENSED",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "heroku-postbuild": "npm run build",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "nest start --watch",
    "start:worker": "node dist/apps/worker/src/main.js",
    "start:worker:dev": "ts-node --files apps/worker/src/main.ts",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deps:check": "depcruise --config .dependency-cruiser.cjs --output-type err --validate .dependency-cruiser.cjs apps libs",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:int": "jest --config test/jest-int.json --runInBand",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run verify:env && npm run deps:check && npm test && npm run openapi:check && npm run openapi:lint",
    "verify:ci-local": "ts-node --files scripts/verify-ci-local.ts",
    "verify:env": "ts-node --files scripts/verify-env-example.ts",
    "verify:project-map": "ts-node --files scripts/verify-project-map-drift.ts",
    "verify:prisma": "ts-node --files scripts/verify-prisma-drift.ts",
    "duplication:core": "jscpd --config .jscpd.json libs/features libs/platform libs/shared apps/worker/src/jobs && ts-node --files scripts/filter-duplication-report.ts --profile core && prettier --write _WIP/duplication-report.md",
    "duplication:small-helpers": "jscpd --config .jscpd.small-helpers.json libs/features libs/platform libs/shared apps/worker/src/jobs && ts-node --files scripts/filter-duplication-report.ts --profile small-helpers && prettier --write _WIP/small-helper-duplication-report.md",
    "duplication:report": "npm run duplication:core && npm run duplication:small-helpers",
    "smells:arch": "ts-node --files scripts/architecture-smells.ts --report _WIP/architecture-smells.md",
    "smells:arch:ci": "ts-node --files scripts/architecture-smells.ts --ci --baseline tools/architecture-smells.baseline.json",
    "scaffold:smoke": "ts-node --files scripts/scaffold-smoke.ts",
    "verify:gates": "ts-node --files scripts/gates-honesty.ts",
    "verify:e2e": "ts-node --files scripts/verify-e2e.ts",
    "commitlint": "commitlint",
    "setup:hooks": "node scripts/install-git-hooks.cjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "openapi:generate": "ts-node --files scripts/openapi-generate.ts",
    "openapi:lint": "spectral lint --fail-severity warn docs/openapi/openapi.yaml",
    "openapi:check": "ts-node --files scripts/openapi-check.ts",
    "deps:up": "docker compose up -d postgres redis minio",
    "deps:down": "docker compose down",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "scaffold:feature": "ts-node --files tools/scaffold-feature.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.5",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "qs": "^6.15.2",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1"
  },
  "overrides": {
    "hono": "^4.12.3",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@stoplight/spectral-cli": "^6.16.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/qs": "^6.15.1",
    "@types/supertest": "^7.2.0",
    "dependency-cruiser": "^17.4.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jscpd": "^4.2.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "yaml": "^2.9.0"
  }
}
