{
  "format": "typescript",
  "minLines": 4,
  "minTokens": 24,
  "mode": "mild",
  "reporters": ["json"],
  "output": "./.tmp/jscpd-small-helpers",
  "silent": true,
  "gitignore": true,
  "ignore": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.int-spec.ts",
    "**/*.e2e-spec.ts",
    "test/**",
    "node_modules/**",
    "dist/**",
    "coverage/**",
    ".tmp/**",
    "**/generated/**",
    "**/migrations/**",
    "docs/openapi/openapi.yaml"
  ]
}
